{
  "name": "homebridge-tesla-powerwall2",
  "displayName": "Tesla Powerwall 2",
  "type": "module",
  "platform": "TeslaPowerwall",
  "version": "4.2.5",
  "description": "Homebridge plugin for Tesla Powerwall 2",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "c8 mocha --exit",
    "test-connection": "node test/integration/test-connection.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkerr64/homebridge-tesla-powerwall2.git"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "homebridge-tesla-powerwall2",
    "Tesla Powerwall",
    "Tesla",
    "Powerwall",
    "battery",
    "solar",
    "energy"
  ],
  "author": "Nick Muldoon",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/dkerr64/homebridge-tesla-powerwall2/issues"
  },
  "homepage": "https://github.com/dkerr64/homebridge-tesla-powerwall2#readme",
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "dependencies": {
    "undici": "^8.4.1",
    "semaphore-promise": "^1.4.4"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.9.2",
    "c8": "^11.0.0",
    "eslint": "^9.39.2",
    "homebridge": "^2.1.0",
    "mocha": "^11.7.6",
    "nock": "^14.0.15",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "maintainers": [
    "dkerr64",
    "nmuldoon"
  ]
}